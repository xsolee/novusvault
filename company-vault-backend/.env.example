# --- Environment ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Dev-only login bypass (auth/dev-login route only exists when both are set this way) ---
ENABLE_DEV_LOGIN=true
DEV_ADMIN_EMAIL=dev-admin@company-vault.local
DEV_ADMIN_NAME=Dev Admin

# Optional: pin the single admin to one Google account. Leave blank to allow whoever logs in first.
ADMIN_ALLOWED_EMAIL=

# --- Database (Supabase Postgres — use the "Direct connection" string from Project Settings ->
# Database, port 5432, NOT the transaction pooler on 6543 — see CLAUDE.md "Infrastructure
# decisions"). Enable the `vector` extension in the Supabase dashboard before running migrations. ---
DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
TEST_DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres_test

# --- Redis (Dramatiq broker + rate limiting) ---
REDIS_URL=redis://redis:6379/0

# --- JWT / token security ---
JWT_SECRET_KEY=dev-only-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Fernet key used to encrypt Google refresh/access tokens at rest.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=changeme-generate-a-real-fernet-key

# --- Google OAuth (leave blank to run on the dev-login bypass only) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/api/v1/drive/callback
FRONTEND_DRIVE_CALLBACK_URL=http://localhost:8081/drive

# --- Object storage (Supabase Storage's S3-compatible endpoint — Project Settings -> Storage ->
# S3 Connection. Separate credential pair from the DB password above. Pull the exact region string
# from that same page — don't assume "us-east-1" generically.) ---
S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
S3_ACCESS_KEY=<supabase-s3-access-key-id>
S3_SECRET_KEY=<supabase-s3-secret-access-key>
S3_BUCKET_NAME=company-vault-documents
S3_REGION=<project-region>

# --- Providers: Ollama is the default so `docker compose up` is demoable with no API key, just a
# self-hosted model in Docker. Set LLM_PROVIDER=anthropic + ANTHROPIC_API_KEY to swap to the
# hosted Claude API instead (embeddings has no hosted alternative wired up — see CLAUDE.md). ---
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=ollama
OCR_PROVIDER=mock

# --- Ollama (in-Docker, default provider — no external account needed) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_REQUEST_TIMEOUT_SECONDS=120

# --- Anthropic (only needed if LLM_PROVIDER=anthropic) ---
# Obtain from console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- RAG tuning (also stored/overridable in application_settings) ---
CHAT_DEPARTMENT_CONFIDENCE_THRESHOLD=0.65
CHAT_DEPARTMENT_GAP_THRESHOLD=0.15
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=150
CHAT_RATE_LIMIT=10/minute

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081
