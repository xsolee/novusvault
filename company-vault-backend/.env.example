# --- Environment ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Dev-only login bypass (auth/dev-login route only exists when both are set this way) ---
ENABLE_DEV_LOGIN=true
DEV_ADMIN_EMAIL=dev-admin@company-vault.local
DEV_ADMIN_NAME=Dev Admin

# Optional: pin the single admin to one Google account. Leave blank to allow whoever logs in first.
ADMIN_ALLOWED_EMAIL=

# --- Database ---
POSTGRES_DB=company_vault
POSTGRES_USER=company_vault
POSTGRES_PASSWORD=company_vault
DATABASE_URL=postgresql+asyncpg://company_vault:company_vault@postgres:5432/company_vault
TEST_DATABASE_URL=postgresql+asyncpg://company_vault:company_vault@postgres:5432/company_vault_test

# --- Redis (Dramatiq broker + rate limiting) ---
REDIS_URL=redis://redis:6379/0

# --- JWT / token security ---
JWT_SECRET_KEY=dev-only-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Fernet key used to encrypt Google refresh/access tokens at rest.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=changeme-generate-a-real-fernet-key

# --- Google OAuth (leave blank to run on the dev-login bypass only) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8000/api/v1/drive/callback
FRONTEND_DRIVE_CALLBACK_URL=http://localhost:8081/drive

# --- Object storage (MinIO locally, any S3-compatible endpoint in production) ---
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=company_vault
S3_SECRET_KEY=company_vault_minio_secret
S3_BUCKET_NAME=company-vault-documents
S3_REGION=us-east-1

# --- Providers: mock is the default so `docker compose up` is demoable with no API keys ---
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=mock
OCR_PROVIDER=mock

# --- RAG tuning (also stored/overridable in application_settings) ---
CHAT_DEPARTMENT_CONFIDENCE_THRESHOLD=0.65
CHAT_DEPARTMENT_GAP_THRESHOLD=0.15
CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=150
CHAT_RATE_LIMIT=10/minute

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081
